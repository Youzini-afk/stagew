# ─── 服务端口 ───────────────────────────────────────────────
# Zeabur 等容器平台会通过 PORT 注入实际端口，请勿在平台上固定 PORT
# 本地不填也会默认 3000
# PORT=3000

# ─── 数据存储 ───────────────────────────────────────────────
# DB_PATH 优先级最高：直接指定 SQLite 文件绝对路径（推荐用于 Zeabur Volume）
# 例如 Zeabur 上挂载 Volume 到 /data 后设置：DB_PATH=/data/accounts.db
DB_PATH=
# DATA_DIR：未设置 DB_PATH 时，数据库文件为 ${DATA_DIR}/accounts.db
DATA_DIR=

# ─── 安全鉴权 ───────────────────────────────────────────────
# 必填：保护 WebUI、账号池、设置、自动注册等管理接口
ADMIN_TOKEN=
# 推荐公网部署设置：OpenAI 客户端使用此 Key 才能消费账号池或 .env 默认 token
PROXY_API_KEY=
# PROXY_API_KEY 的兼容别名，二选一即可
# API_KEY=

# ─── Stagewise 接口 ────────────────────────────────────────
STAGEWISE_LLM_URL=https://api.stagewise.io/v1/ai
STAGEWISE_API_URL=https://api.stagewise.io
STAGEWISE_TOKEN=

# ─── 临时邮箱服务 ───────────────────────────────────────────
# 可选：gptmail / cfmail。未设置时默认 gptmail。
MAIL_PROVIDER=gptmail

# GPTMail 临时邮箱
MAIL_URL=https://mail.chatgpt.org.uk
MAIL_TOKEN=

# CFMail Worker 临时邮箱（示例占位，勿提交真实 api_base/api_key）
# MAIL_PROVIDER=cfmail
# CFMAIL_API_BASE=https://your-cfmail-worker.example.workers.dev
# CFMAIL_API_KEY=replace-with-your-cfmail-admin-key
# CFMAIL_DOMAINS=example.com,example.net

# CFMail 高级选项（默认适配常见 Worker 接口）
# CFMAIL_ADMIN_AUTH_HEADER=x-admin-auth
# CFMAIL_ADMIN_AUTH_SCHEME=raw
# CFMAIL_MAILBOX_AUTH_HEADER=Authorization
# CFMAIL_MAILBOX_AUTH_SCHEME=bearer
# CFMAIL_CREATE_ENDPOINT=/admin/new_address
# CFMAIL_LIST_ENDPOINT=/api/mails
# CFMAIL_HEALTH_ENDPOINT=/healthz

# ─── 代理池 ─────────────────────────────────────────────────
# 自动注册时按策略选代理。支持：
#   - 直连协议：http://、https://、socks5://（undici 原生，无需 mihomo）
#   - 高级协议：ss、vmess、vless、trojan、hysteria2/hy2、tuic（需 mihomo 子进程聚合）
# 支持订阅导入：Clash/Mihomo YAML（仅读取顶层 proxies）、base64 URI list、plain URI list。

# 启用代理池（默认 false）。启用后从 DB 节点池选代理；未启用或池空时降级到 PROXY_URL
# PROXY_POOL_ENABLED=false
# 种子节点列表（逗号或换行分隔，DB 无节点时导入；示例占位，勿提交真实凭证）
# PROXY_POOL_URLS=http://user:pass@proxy1.example.com:8080,socks5://127.0.0.1:1080
# 直连节点策略：round-robin（默认）或 random
# PROXY_POOL_STRATEGY=round-robin
# 降级代理：代理池关闭或空时使用（可为空，直连）
# PROXY_URL=

# ─── mihomo 子进程（高级协议聚合） ───────────────────────────
# 池中存在 ss/vmess/vless/trojan/hysteria2/tuic 等高级协议节点时，由本地 mihomo
# 子进程聚合成一个 http://127.0.0.1:<mixed-port> 入口，自动注册走该入口。
# Docker 镜像已内置固定版本 mihomo 二进制；本地/源码部署需自行安装 mihomo 并设置 MIHOMO_PATH。
# 高级节点存在但 mihomo 不可用时，注册会 fail closed（拒绝直连）而非静默走直连。

# 是否启用 mihomo（默认 true；设 false 时遇高级节点会直接 fail closed）
# MIHOMO_ENABLED=true
# mihomo 二进制路径（Docker 镜像默认 /usr/local/bin/mihomo；本地部署按实际路径）
# MIHOMO_PATH=mihomo
# 本地混合代理端口（仅绑定 127.0.0.1）
# MIHOMO_MIXED_PORT=7890
# external-controller 端口（仅绑定 127.0.0.1；secret 自动生成不返回前端）
# MIHOMO_CONTROLLER_PORT=9090
# REG_AUTO 组策略：fallback（默认）/ url-test / load-balance
# MIHOMO_GROUP_STRATEGY=fallback
# url-test/fallback 探活 URL
# MIHOMO_TEST_URL=https://www.gstatic.com/generate_204
